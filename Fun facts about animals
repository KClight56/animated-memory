<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Random Animal Fun Facts</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f3f8ff;
      text-align: center;
      padding-top: 60px;
    }
    #fact-box {
      background: #fff;
      color: #333;
      border: 1px solid #e2e8f0;
      box-shadow: 0 2px 12px #c8c8c833;
      margin: 0 auto 20px auto;
      max-width: 500px;
      padding: 30px 20px;
      font-size: 1.3em;
      border-radius: 12px;
      min-height: 80px;
      transition: box-shadow 0.2s;
    }
    button {
      padding: 10px 35px;
      font-size: 1em;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 7px;
      cursor: pointer;
      box-shadow: 0 2px 10px #00000019;
      transition: background 0.2s;
    }
    button:hover {
      background: #1c46af;
    }
  </style>
</head>
<body>

  <h1>Random Animal Fun Facts!</h1>
  <div id="fact-box">Click the button to see a fun animal fact!</div>
  <button onclick="showRandomFact()">Show Another Fact</button>

  <script>
    const facts = [
      "A group of flamingos is called a ‘flamboyance’.",
      "Otters hold hands while sleeping so they don’t drift apart.",
      "Elephants are the only animals that can’t jump.",
      "A snail can sleep for up to three years.",
      "Cows have best friends and can become stressed if they are separated.",
      "Wombat poop is cube-shaped!",
      "The fingerprints of a koala are so close to humans that they can taint crime scenes.",
      "Dolphins have names for each other and can remember them for years.",
      "Octopuses have three hearts.",
      "Some turtles can breathe through their butts.",
      "Frogs can freeze without dying and thaw later to hop away.",
      "Parrots will selflessly help each other without immediate gain.",
      "Sloths only poop once a week—and risk their lives to do it!",
      "The heart of a shrimp is located in its head.",
      "Sea otters have pockets under their arms."
    ];

    function showRandomFact() {
      const factBox = document.getElementById('fact-box');
      const randomFact = facts[Math.floor(Math.random() * facts.length)];
      factBox.textContent = randomFact;
    }
  </script>
</body>
</html>
